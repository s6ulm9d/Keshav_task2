{% extends "layout.njk" %}

{% set title = "Home" %}
{% set activePage = "home" %}

{% block content %}
    <!-- Hero Section -->
    <header class="hero-section">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-6 mb-5 mb-lg-0 text-center text-lg-start">
                    <h1 class="display-4 mb-3 animate-text">Accelerate Your Digital <span class="text-primary">Evolution</span></h1>
                    <p class="lead mb-4 text-muted animate-text delay-1">Empowering businesses with cutting-edge technology solutions that drive growth, efficiency, and innovation in the digital era.</p>
                    <div class="d-flex flex-column flex-sm-row justify-content-center justify-content-lg-start gap-3 animate-text delay-2">
                        <a href="/about.html" class="btn btn-primary btn-lg">Explore Services</a>
                        <a href="/contact.html" class="btn btn-outline-primary btn-lg">Learn More</a>
                    </div>
                </div>
                <div class="col-lg-6" data-aos="fade-left" data-aos-duration="1000">
                    <img id="hero-image" src="/src/assets/hero.png" alt="Keshav Tech Illustration" class="img-fluid hero-img w-100">
                </div>
            </div>
        </div>
    </header>

    <!-- Features Section -->
    <section class="py-5" id="features">
        <div class="container py-5">
            <div class="text-center mb-5">
                <h2 class="mb-3">Why Choose Keshav?</h2>
                <p class="text-muted mx-auto" style="max-width: 600px;">We combine industry-leading expertise with innovative techniques to deliver results that exceed expectations.</p>
            </div>
            <div class="row g-4">
                <!-- Feature 1 -->
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="100">
                    <div class="custom-card p-4 shadow-sm h-100">
                        <div class="icon-box mb-3 text-primary fs-1">
                            <i class="fa-solid fa-cloud"></i>
                        </div>
                        <h3>Modern Infrastructure</h3>
                        <p class="text-muted">Scale with confidence using our robust and secure cloud-native infrastructure solutions.</p>
                    </div>
                </div>
                <!-- Feature 2 -->
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="200">
                    <div class="custom-card p-4 shadow-sm h-100">
                        <div class="icon-box mb-3 text-primary fs-1">
                            <i class="fa-solid fa-microchip"></i>
                        </div>
                        <h3>AI Integration</h3>
                        <p class="text-muted">Harness the power of machine learning and artificial intelligence to automate your workflows.</p>
                    </div>
                </div>
                <!-- Feature 3 -->
                <div class="col-md-4" data-aos="fade-up" data-aos-delay="300">
                    <div class="custom-card p-4 shadow-sm h-100">
                        <div class="icon-box mb-3 text-primary fs-1">
                            <i class="fa-solid fa-shield-halved"></i>
                        </div>
                        <h3>Security First</h3>
                        <p class="text-muted">Enterprise-grade security protocols integrated into every layer of our development process.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="py-5 bg-primary text-white text-center">
        <div class="container py-4">
            <h2 class="mb-4">Ready to transform your business?</h2>
            <p class="lead mb-5 opacity-75">Join dozens of high-growth companies pushing the boundaries of what's possible.</p>
            <a href="/contact.html" class="btn btn-light btn-lg px-5 text-primary fw-bold">Contact Us Today</a>
        </div>
    </section>
{% endblock %}
