{% extends "layout.njk" %}

{% set title = "Contact Us" %}
{% set activePage = "contact" %}

{% block content %}
    <!-- Page Header -->
    <header class="py-5 bg-dark text-white">
        <div class="container py-lg-4 text-center">
            <h1 class="display-4 animate-text">Start Your <span class="text-primary">Journey</span></h1>
            <p class="lead opacity-75 animate-text delay-1">Have a project in mind? Let's talk about how we can help you achieve your goals.</p>
        </div>
    </header>

    <!-- Contact Form Section -->
    <section class="py-5">
        <div class="container py-5">
            <div class="row g-5">
                <!-- Contact Info -->
                <div class="col-lg-5" data-aos="fade-right">
                    <h2 class="mb-4">Get in Touch</h2>
                    <p class="text-muted mb-5">Fill out the form and our team will get back to you within 24 hours. We're excited to hear from you!</p>
                    
                    <div class="d-flex mb-4">
                        <div class="icon-box text-primary fs-3 me-3">
                            <i class="fa-solid fa-location-dot"></i>
                        </div>
                        <div>
                            <h5>Our Studio</h5>
                            <p class="text-muted">123 Tech Way, Innovation Hub<br>San Francisco, CA 94103</p>
                        </div>
                    </div>

                    <div class="d-flex mb-4">
                        <div class="icon-box text-primary fs-3 me-3">
                            <i class="fa-solid fa-envelope"></i>
                        </div>
                        <div>
                            <h5>Email Us</h5>
                            <p class="text-muted">hello@keshav-solutions.com<br>support@keshav-solutions.com</p>
                        </div>
                    </div>

                    <div class="d-flex">
                        <div class="icon-box text-primary fs-3 me-3">
                            <i class="fa-solid fa-phone"></i>
                        </div>
                        <div>
                            <h5>Call Us</h5>
                            <p class="text-muted">+1 (555) 000-1234</p>
                        </div>
                    </div>
                </div>

                <!-- Form -->
                <div class="col-lg-7" data-aos="fade-left">
                    <div class="custom-card p-4 p-md-5 shadow">
                        <form id="contactForm" class="needs-validation" novalidate>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="firstName" class="form-label fw-bold">First Name</label>
                                    <input type="text" class="form-control bg-light border-0 py-3" id="firstName" placeholder="John" required>
                                    <div class="invalid-feedback">Please provide your first name.</div>
                                </div>
                                <div class="col-md-6">
                                    <label for="lastName" class="form-label fw-bold">Last Name</label>
                                    <input type="text" class="form-control bg-light border-0 py-3" id="lastName" placeholder="Doe" required>
                                    <div class="invalid-feedback">Please provide your last name.</div>
                                </div>
                                <div class="col-12">
                                    <label for="email" class="form-label fw-bold">Email Address</label>
                                    <input type="email" class="form-control bg-light border-0 py-3" id="email" placeholder="john@example.com" required>
                                    <div class="invalid-feedback">Please provide a valid email address.</div>
                                </div>
                                <div class="col-12">
                                    <label for="subject" class="form-label fw-bold">Subject</label>
                                    <select class="form-select bg-light border-0 py-3" id="subject">
                                        <option selected>General Inquiry</option>
                                        <option value="1">Request a Quote</option>
                                        <option value="2">Technical Support</option>
                                        <option value="3">Partnership Opportunity</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label for="message" class="form-label fw-bold">Your Message</label>
                                    <textarea class="form-control bg-light border-0 py-3" id="message" rows="5" placeholder="Tell us about your project..." required></textarea>
                                    <div class="invalid-feedback">Please enter your message.</div>
                                </div>
                                <div class="col-12">
                                    <button type="submit" class="btn btn-primary btn-lg w-100 py-3">Send Message</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>
{% endblock %}

{% block scripts %}
<script>
    // Form Validation
    (() => {
        'use strict'
        const forms = document.querySelectorAll('.needs-validation')
        Array.from(forms).forEach(form => {
            form.addEventListener('submit', event => {
                if (!form.checkValidity()) {
                    event.preventDefault()
                    event.stopPropagation()
                }
                form.classList.add('was-validated')
            }, false)
        })
    })()
</script>
{% endblock %}
